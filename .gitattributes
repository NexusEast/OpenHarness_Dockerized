# Force LF line endings for files that MUST be LF to execute on *nix / inside the container.
# Without this, a Windows clone (core.autocrlf=true) would convert them to CRLF and bash
# would barf with `bad interpreter` or `'\r': command not found`.

*.sh                  text eol=lf
*.bash                text eol=lf
Dockerfile            text eol=lf
docker/entrypoint.sh  text eol=lf
Makefile              text eol=lf

# These can keep platform-native line endings.
*.ps1                 text eol=crlf
*.psm1                text eol=crlf
*.cmd                 text eol=crlf
*.md                  text
*.json                text
*.toml                text
*.yml                 text
*.yaml                text
